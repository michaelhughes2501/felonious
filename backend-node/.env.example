DB_HOST=localhost
DB_USER=root
DB_PASS=yourpassword
DB_NAME=felonious
PORT=5001

# JWT — change this to a long random string in production
JWT_SECRET=replace-with-a-long-random-secret

# AI provider for The Clerk (uncomment one)
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# Google OAuth for the /integrations (Hookups) panel.
# Create a Web Application client in Google Cloud Console and register
# http://localhost:5001/integrations/callback as an authorized redirect URI.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
